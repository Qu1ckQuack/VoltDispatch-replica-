# ============================================================================
# Database
# ============================================================================
# Superuser connection — used ONLY for Prisma Migrate (DDL).
DATABASE_URL=postgresql://postgres:your-password-here@db.ref.supabase.co:5432/postgres

# Restricted-role connection — used at runtime with RLS enforced.
# DATABASE_URL_RUNTIME=postgresql://app_nest:password@db.ref.supabase.co:5432/postgres

# ============================================================================
# Auth
# ============================================================================
JWT_SECRET=generate-a-random-64-hex-secret-with-openssl-rand
BCRYPT_ROUNDS=10

# ============================================================================
# Server
# ============================================================================
PORT=3001

# ============================================================================
# Redis (Upstash)
# ============================================================================
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# ============================================================================
# Object storage (AWS S3 or Supabase Storage S3-compatible)
# ============================================================================
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-southeast-1

# ============================================================================
# Notification providers
# ============================================================================
RESEND_API_KEY=re_UAkQNQXW_KLs5u8cTHrr93xqmkopxpQDe
EMAIL_FROM=onboarding@resend.dev
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ============================================================================
# CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ============================================================================
# Frontend URL (used for rating links in notifications)
# ============================================================================
FRONTEND_URL=http://localhost:3000
